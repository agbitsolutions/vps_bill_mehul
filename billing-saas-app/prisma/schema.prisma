datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id                Int      @id @default(autoincrement())
  name              String
  price             Float
  stock             Int      @default(0)
  lowStockThreshold Int      @default(5)
  createdAt         DateTime @default(now())
}

model Bill {
  id           Int      @id @default(autoincrement())
  customerName String
  totalAmount  Float
  createdAt    DateTime @default(now())
}
